# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Postgres ---
POSTGRES_USER=tradesync
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=tradesync
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Qdrant ---
QDRANT_PORT=6333

# --- Service Ports ---
STATE_API_PORT=8000
INGEST_PORT=8080
FUSION_ENGINE_PORT=8002
HL_EXEC_PORT=8004
DRIFT_EXEC_PORT=8003

# --- Execution (Phase 3E - leave blank until wallet integration is complete) ---
HYPERLIQUID_WALLET_PK=
DRIFT_RPC_URL=
DRIFT_WALLET_PRIVATE_KEY=
DRY_RUN=true

# --- Phase 3C: Market Microstructure & Risk Guardian ---
MAX_SPREAD_BPS=50.0
OPTIMAL_SPREAD_BPS=2.0
MIN_DEPTH_25BP_USD=100000
MAX_IMPACT_BPS_5K=25.0
MIN_LIQUIDITY_SCORE=0.3
MARGIN_STRESS_THRESHOLD=0.8
MAX_EXPOSURE_PER_SYMBOL_USD=25000

# --- Phase 3C: Macro Feed ---
MACRO_FEED_CACHE_TTL=300
MACRO_RSS_SOURCES='[{"name": "Cointelegraph", "url": "https://cointelegraph.com/rss/tag/bitcoin", "category": "crypto"}, {"name": "CoinDesk", "url": "https://www.coindesk.com/arc/outboundfeeds/rss/", "category": "crypto"}]'
